@startuml
'!theme plain

node "Player 1 Controller" as P1_Ctrl {
  port "Throttle (Analog)" as P1_A
  port "Button (Digital)" as P1_D
}
node "Player 2 Controller" as P2_Ctrl {
  port "Throttle (Analog)" as P2_A
  port "Button (Digital)" as P2_D
}

node "Raspberry Pi Pico (Input MCU)" as Pico {
  port "ADC0 (Pin 26)" as pADC1
  port "GP21 (IN)" as pD1
  port "ADC1 (Pin 27)" as pADC2
  port "GP20 (IN)" as pD2
  port "UART0 TX (Pin 0)" as pTX
  port "UART0 RX (Pin 1)" as pRX
}

P1_A --> pADC1
P1_D --> pD1
P2_A --> pADC2
P2_D --> pD2

node "Raspberry Pi 4 (Core Host)" as RPi4 {
  port "UART RX" as rRX
  port "UART TX" as rTX
  port "GPIO 18 (PWM0)" as rGPIO18
  port "GPIO 19 (PWM1)" as rGPIO19
  port "Audio Out (USB)" as rAudio
}

pTX --> rRX : Serial Data \n(typically 115200 baud)
pRX <-- rTX

node "Output Devices" {
  node "Round Counter 0 (8x8 LED Matrix)" as Matrix0
  node "Track 0 LED Strip (WS2812B)" as Track0
  node "Intersection 0 LED Strip (WS2812B)" as Intersection0
  
  node "Round Counter 1 (8x8 LED Matrix)" as Matrix1
  node "Track 1 LED Strip (WS2812B)" as Track1
  node "Intersection 1 LED Strip (WS2812B)" as Intersection1
  
  node "Stereo Speakers" as Speakers
}

rGPIO18 --> Matrix0 : Data In
Matrix0 --> Track0 : DOUT -> DIN
Track0 --> Intersection0

rGPIO19 --> Matrix1 : Data In
Matrix1 --> Track1 : DOUT -> DIN
Track1 --> Intersection1

rAudio --> Speakers : Stereo Audio

' --- Layout Ordering Constraints ---
P1_Ctrl -[hidden]right-> P2_Ctrl
P1_Ctrl -[hidden]down-> pD2
P2_Ctrl -[hidden]down-> pRX
'pTX -[hidden]down-> rRX
'rRX -[hidden]down-> Matrix0
@enduml